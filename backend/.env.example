# ============================================================
# FICHIER EXEMPLE — VARIABLES D'ENVIRONNEMENT
# Copier ce fichier sous le nom .env et remplir les valeurs.
# Ce fichier PEUT être commité dans Git (pas de vraies clés).
# ============================================================

# --- API OMDb (recherche de films) ---
# Obtenir une clé gratuite sur : https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# --- API Spoonacular (recherche de recettes/ingrédients) ---
# Obtenir une clé gratuite sur : https://spoonacular.com/food-api
SPOONACULAR_API_KEY=

# --- API OpenRouter (génération IA) ---
# Créer un compte sur : https://openrouter.ai/
OPENROUTER_API_KEY=

# --- MongoDB ---
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=labo1